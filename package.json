{
  "name": "open-tools-starter",
  "version": "0.2.2",
  "private": true,
  "type": "module",
  "description": "A local-first, privacy-friendly starter template for pure frontend GitHub Pages tools.",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "self-test": "node scripts/run-self-test.mjs",
    "preflight": "node scripts/preflight.mjs",
    "test:static": "node scripts/test-static.mjs",
    "test:config": "node scripts/test-config.mjs",
    "test:docs": "node scripts/test-docs.mjs",
    "test:health": "node scripts/test-project-health.mjs",
    "test:privacy": "node scripts/test-privacy-boundary.mjs",
    "test:usability": "node scripts/test-template-usability.mjs",
    "test:ui": "node scripts/test-ui-contract.mjs",
    "test:dist": "node scripts/test-dist.mjs",
    "test:pressure": "node scripts/pressure-test.mjs",
    "test:all": "npm run test:static && npm run test:config && npm run test:docs && npm run test:health && npm run test:privacy && npm run test:usability && npm run build && npm run self-test && npm run test:dist && npm run test:ui && npm run preflight",
    "test:ci": "npm run test:all && PRESSURE_ROUNDS=2 npm run test:pressure"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  },
  "engines": {
    "node": ">=18"
  }
}
