{
  "name": "repo-galaxy-studio",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "description": "Turn your GitHub public repos into an interactive 3D galaxy. Local First, No Backend, GitHub Pages Ready.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/w0nderful666/repo-galaxy-studio"
  },
  "homepage": "https://w0nderful666.github.io/repo-galaxy-studio/",
  "keywords": [
    "github",
    "3d",
    "galaxy",
    "three.js",
    "react",
    "typescript",
    "visualization",
    "github-pages",
    "local-first",
    "no-backend"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "self-test": "node scripts/run-self-test.mjs",
    "preflight": "node scripts/preflight.mjs",
    "test:all": "npm run build && npm run self-test && npm run preflight"
  },
  "dependencies": {
    "@react-three/drei": "^9.115.0",
    "@react-three/fiber": "^8.17.10",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.170.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/three": "^0.170.0",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  },
  "engines": {
    "node": ">=18"
  }
}
